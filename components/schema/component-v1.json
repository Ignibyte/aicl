{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aicl-component-v1",
  "title": "AICL Component Manifest v1",
  "description": "Schema for validating AICL SDC component.json manifests",
  "type": "object",
  "required": ["$schema", "name", "tag", "category", "status", "description", "context", "props", "decision_rule"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "aicl-component-v1"
    },
    "name": {
      "type": "string",
      "description": "Human-readable component name",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "description": "Blade component tag (e.g., x-aicl-stat-card)",
      "pattern": "^x-aicl-[a-z][a-z0-9-]*$"
    },
    "category": {
      "type": "string",
      "enum": ["metric", "data", "collection", "action", "status", "timeline", "layout", "feedback", "utility"],
      "description": "Component category for grouping and discovery"
    },
    "status": {
      "type": "string",
      "enum": ["experimental", "stable", "deprecated"],
      "description": "Component maturity status"
    },
    "description": {
      "type": "string",
      "description": "One-sentence description of what this component does",
      "minLength": 1
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["blade", "livewire", "filament-widget", "email", "pdf", "cms-builder", "entity-display"]
      },
      "minItems": 1,
      "description": "Valid rendering contexts"
    },
    "not_for": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["filament-form", "filament-table", "filament-infolist"]
      },
      "description": "Explicit context exclusions"
    },
    "props": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "PHP-style type (string, number, boolean, array, object, or union with |)"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "default": {
            "description": "Default value for the prop"
          },
          "description": {
            "type": "string"
          },
          "enum": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Allowed values for enum-type props"
          }
        }
      },
      "description": "Typed prop definitions"
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          }
        }
      },
      "description": "Named slot definitions"
    },
    "variants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "props_override": {
            "type": "object",
            "description": "Prop overrides for this variant"
          }
        }
      },
      "description": "Named presets with optional prop overrides"
    },
    "composable_in": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Parent component tags this can be nested inside"
    },
    "decision_rule": {
      "type": "string",
      "description": "When the AI should select this component (plain English)",
      "minLength": 1
    },
    "field_signals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Entity field types/patterns that trigger this recommendation"
    },
    "filament_equivalent": {
      "type": "object",
      "properties": {
        "context": {
          "type": "string"
        },
        "class": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "description": "What to use instead when in a Filament declarative context"
    },
    "cms_block": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["layout", "content"],
          "description": "Block tier: layout blocks have drop zones, content blocks are leaf nodes"
        },
        "icon": {
          "type": "string",
          "description": "Heroicon name for the builder palette"
        },
        "drop_zones": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Named drop zones for layout blocks (empty array for content blocks)"
        },
        "allowed_in_regions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Which template regions this block can be placed in"
        }
      },
      "required": ["tier", "icon", "drop_zones"],
      "description": "CMS page builder configuration. If present, component appears in the builder palette."
    },
    "entity_display": {
      "type": "object",
      "properties": {
        "content_type": {
          "type": "string",
          "description": "Content type machine name this component displays (matches ContentType::machineName())"
        },
        "display_mode": {
          "type": "string",
          "description": "Display mode name (e.g., teaser, card, badge, row)"
        },
        "field_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Maps component props to entity model fields. Keys are prop names, values are model field paths (supports dot notation for relations)"
        }
      },
      "required": ["content_type", "display_mode", "field_mapping"],
      "description": "Entity display configuration. If present, component renders a specific entity type in a specific display mode."
    }
  }
}
